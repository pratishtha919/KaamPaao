# Copy to .env and fill in real values. Never commit .env.
# Generate a key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-openssl-rand-hex-32

# development | production
FLASK_ENV=development

# Path is relative to the Flask instance folder (instance/)
DATABASE_PATH=kaampaao.db

# Optional: seed an admin user the first time init_db.py runs.
# Leave SEED_ADMIN_EMAIL or SEED_ADMIN_PHONE blank to skip. Both required when seeding.
# Phone is E.164 format, e.g. +919999999999. Admins log in via phone+OTP.
SEED_ADMIN_NAME=KaamPaao Admin
SEED_ADMIN_EMAIL=
SEED_ADMIN_PHONE=

# OTP delivery: "dev" (print to console + return in API for dev banner) or "log".
# Real SMS providers (twilio, msg91) are stubbed for future work.
OTP_PROVIDER=dev
